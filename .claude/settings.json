{
  "plansDirectory": "./plans",
  "respectGitignore": true,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "auto",
  "mcpToolSearchThreshold": "auto:5",
  "permissions": {
    "allow": [
      "Bash(xcodebuild *)",
      "Bash(swift *)",
      "Bash(swiftlint *)",
      "Bash(xcrun *)",
      "Bash(simctl *)",
      "Bash(git *)",
      "Bash(open *.xcodeproj)",
      "Bash(open *.xcworkspace)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *.swift)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(uv *)",
      "Bash(which *)",
      "Bash(ls *)",
      "Task(agent_type=general-purpose)",
      "Task(agent_type=Explore)",
      "Task(agent_type=Plan)",
      "Task(agent_type=Bash)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/project-setup.py",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/safety-check.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/permission-request.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/notification.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/user-prompt-submit.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/subagent-tracker.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/subagent-tracker.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/tool-failure-tracker.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/task-completed.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/teammate-idle.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/caseysimon/HealthAppTransfer/.claude/hooks/session-logger.py",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
